#!/usr/bin/env bash
# bin/claude-agent — JIT wrapper: inject secrets process-scoped, exec `claude`.
# Installed to ~/bin; AGENT_SECRETS_ROOT baked at top, env-overridable.
set -euo pipefail
# Resolve the true install root by following symlinks (this wrapper is symlinked onto PATH, away
# from its sibling lib/). Env-overridable for tests/drills.
_self="${BASH_SOURCE[0]:-$0}"
while [ -h "$_self" ]; do _d=$(cd -P "$(dirname "$_self")" >/dev/null 2>&1 && pwd); _self=$(readlink "$_self"); case "$_self" in /*) : ;; *) _self="$_d/$_self" ;; esac; done
AGENT_SECRETS_ROOT="${AGENT_SECRETS_ROOT:-$(cd -P "$(dirname "$_self")/.." >/dev/null 2>&1 && pwd)}"
# shellcheck source=lib/common.sh
. "$AGENT_SECRETS_ROOT/lib/common.sh"
# shellcheck source=lib/keychain.sh
. "$AGENT_SECRETS_ROOT/lib/keychain.sh"
# shellcheck source=lib/store.sh
. "$AGENT_SECRETS_ROOT/lib/store.sh"
# shellcheck source=lib/egress.sh
. "$AGENT_SECRETS_ROOT/lib/egress.sh"
[ -f "$(agsec_store_file)" ] || agsec_die "no store found — run: agent-secrets setup"
egress_run -- claude "$@"   # inject secrets + (if an allowlist is configured) bound egress
