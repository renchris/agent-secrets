#!/usr/bin/env bash
# bin/agent-secrets — verb dispatcher. Do not edit by hand: the case table is the stable routing surface.
# Command behavior lives in cmd/*.sh + lib/*.sh; this file only routes.
# Names-only: this dispatcher never handles or prints a secret value.
set -euo pipefail

# --- Resolve own install root (follow symlinks) so cmd/ and lib/ are locatable ---
_self="${BASH_SOURCE[0]:-$0}"
while [ -h "$_self" ]; do
  _d=$(cd -P "$(dirname "$_self")" >/dev/null 2>&1 && pwd)
  _self=$(readlink "$_self")
  case "$_self" in /*) : ;; *) _self="$_d/$_self" ;; esac
done
AGENT_SECRETS_BIN=$(cd -P "$(dirname "$_self")" >/dev/null 2>&1 && pwd)
AGENT_SECRETS_ROOT=$(dirname "$AGENT_SECRETS_BIN")
AGENT_SECRETS_LIB="$AGENT_SECRETS_ROOT/lib"
AGENT_SECRETS_CMD="$AGENT_SECRETS_ROOT/cmd"
export AGENT_SECRETS_ROOT AGENT_SECRETS_LIB AGENT_SECRETS_CMD

# --- Leading global flags (before the verb). --plain is exported so the exec'd ---
# --- cmd re-sources common.sh in plain mode (NO_COLOR parity). --------
while [ "${1:-}" != "" ]; do
  case "$1" in
    --plain)     export AGENT_SECRETS_PLAIN=1; shift ;;
    --no-color)  export NO_COLOR=1; shift ;;
    -V|--version) printf 'agent-secrets %s\n' \
                    "$(sed -n 's/^AGENT_SECRETS_VERSION="\(.*\)".*/\1/p' "$AGENT_SECRETS_LIB/common.sh" 2>/dev/null || echo '0.1.0')"
                  exit 0 ;;
    *) break ;;
  esac
done

# shellcheck source=lib/common.sh
. "$AGENT_SECRETS_LIB/common.sh"
# shellcheck source=lib/help.sh
. "$AGENT_SECRETS_LIB/help.sh"

usage() { agsec_help_render top; }   # single source of truth: lib/help.sh

# True if a help flag appears BEFORE any `--` separator — intercepts `<verb> --help` before the
# verb's body runs (critical: `uninstall --help` must never start removal), while leaving
# `run -- <cmd> --help` alone (there `--help` belongs to the child command).
_wants_help() { local a; for a in "$@"; do case "$a" in --) return 1 ;; -h|--help) return 0 ;; esac; done; return 1; }

_reserved() {  # v0.1 stub for verbs deferred to v0.2
  printf '%s\n' "agent-secrets: '$1' is reserved for v0.2 and not available in ${AGENT_SECRETS_VERSION}." >&2
  case "$1" in
    rotate) printf '%s\n' "  For now: manifest 'rotate_by' rows + the weekly smoke job track rotation due-dates." >&2 ;;
    demo)   printf '%s\n' "  For now: set AGENT_SECRETS_HOME to a synthetic dir for isolated demos/tests." >&2 ;;
  esac
  exit 2
}

_dispatch() {  # exec the verb's script with remaining args; process-clean
  local script="$AGENT_SECRETS_CMD/$1.sh"; shift
  [ -f "$script" ] || agsec_die "internal: missing command script for '$(basename "$script" .sh)'"
  exec bash "$script" "$@"
}

verb="${1:-help}"; [ "$#" -gt 0 ] && shift || true

# Per-command help interception — render help and exit WITHOUT running the command body.
case "$verb" in
  setup|add|list|ls|run|doctor|uninstall|share|receive|pubkey)
    if _wants_help "$@"; then
      hv="$verb"; [ "$hv" = ls ] && hv=list
      agsec_help_render "$hv"; exit 0
    fi ;;
esac

case "$verb" in
  setup)          _dispatch setup "$@" ;;
  add)            _dispatch add "$@" ;;
  list|ls)        _dispatch list "$@" ;;
  run)            _dispatch run "$@" ;;
  doctor)         _dispatch doctor "$@" ;;
  uninstall)      _dispatch uninstall "$@" ;;
  share)          _dispatch share "$@" ;;
  receive)        _dispatch receive "$@" ;;
  pubkey)         _dispatch pubkey "$@" ;;
  rotate)         _reserved rotate ;;
  demo)           _reserved demo ;;
  version)        printf 'agent-secrets %s\n' "$AGENT_SECRETS_VERSION" ;;
  --json)         agsec_help_json ;;                       # machine-readable manifest (agents)
  help|--help|-h)
    case "${1:-}" in
      --json)     agsec_help_json ;;                       # `help --json`
      '')         agsec_help_render top ;;
      *)          agsec_help_render "$1" ;;                # `help <command>`
    esac ;;
  *)              agsec_die "unknown command: '$verb' (try: agent-secrets help)" 2 ;;
esac
